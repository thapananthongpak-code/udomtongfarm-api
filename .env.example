# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Database (Turso) ─────────────────────────────────────────────────────────
# หาได้จาก https://turso.tech → Dashboard → Database → Connect
TURSO_DB_URL=libsql://your-db-name.turso.io
TURSO_DB_TOKEN=your_turso_db_token

# ─── CORS — ระบุทุก origin ที่ frontend รัน (คั่นด้วย comma) ─────────────────
# ตัวอย่าง: http://localhost:5173,https://udomtongfarm.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# ─── Admin Secret (ใช้เรียก /setup-db /setup-species /setup-admin) ───────────
# สุ่มได้ด้วย: openssl rand -base64 32
ADMIN_SECRET=change_this_to_a_strong_random_secret

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# ต้องเปิด "App Password" ใน Google Account (ไม่ใช่รหัส Gmail ปกติ)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_google_app_password
